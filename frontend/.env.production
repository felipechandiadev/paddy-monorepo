# Frontend Port Configuration
PORT=3001

# Backend API Configuration - Production
# Use relative path to work through reverse proxy, or update with actual production backend URL
NEXT_PUBLIC_API_URL=/api/v1

# JWT Token Storage Key
JWT_TOKEN_STORAGE_KEY=paddy_token

# NextAuth Configuration - Update with your production domain
NEXTAUTH_URL=https://paddy.ayg-chile.cloud

# API Configuration
API_TIMEOUT=30000
NEXTAUTH_SECRET=your_nextauth_secret_key_change_in_production
