{
  "name": "paddy-backend",
  "version": "1.0.0",
  "description": "Rice reception & financial management system - DDD Architecture",
  "author": "Paddy Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:migrate": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/infrastructure/database/data-source.ts migration:run",
    "db:migrate:create": "npm run typeorm -- migration:create",
    "db:backfill:advance-transactions": "ts-node -r tsconfig-paths/register backfill-advance-transactions.ts",
    "db:backfill:settlement-iva-services": "ts-node -r tsconfig-paths/register backfill-settlement-iva-services.ts",
    "db:backfill:settlement-reception-snapshots": "ts-node -r tsconfig-paths/register backfill-settlement-reception-snapshots.ts",
    "db:seed": "node dist/infrastructure/persistence/seeders/seed-minimal.js",
    "db:seed:full": "node dist/infrastructure/persistence/seeders/seed.js",
    "seed:expanded": "ts-node -r tsconfig-paths/register src/infrastructure/persistence/seeders/seed-expanded.ts",
    "db:reset": "ts-node db-reset.ts",
    "db:setup": "npm run db:reset && npm run build && npm run db:seed",
    "db:setup:full": "npm run db:reset && npm run build && npm run db:seed:full",
    "seed:test-cosecha": "ts-node -r tsconfig-paths/register src/infrastructure/persistence/seeders/seed-test-cosecha.ts",
    "db:setup:test-cosecha": "npm run db:reset && npm run build && npm run seed:test-cosecha",
    "seed:production": "ts-node -r tsconfig-paths/register src/infrastructure/persistence/seeders/seed-production.ts",
    "db:setup:production": "npm run seed:production",
    "backup:db": "ts-node -r tsconfig-paths/register src/infrastructure/database/cli/backup-cli.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.3",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.3",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/typeorm": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "joi": "^17.11.0",
    "luxon": "^3.7.2",
    "mysql2": "^3.6.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.3",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^3.0.13",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
